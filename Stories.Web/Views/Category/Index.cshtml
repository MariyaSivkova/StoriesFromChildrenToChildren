@using Stories.ViewModels.Category
@model IEnumerable<CategoryViewModel>
@{
    ViewData["Title"] = "All Categories";
}

<div class="d-flex justify-content-between align-items-center mb-3" style="margin-top: 20px;">
    <h2>@ViewData["Title"]</h2>

    @if (User?.Identity?.IsAuthenticated == true)
    {
        <a asp-controller="Category" asp-action="Add" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add New Category
        </a>
    }
</div>


<div class="row text-center">
    @foreach (var category in Model)
    {
        <div class="col-md-3 mb-4">
            <div class="card h-100" style="width: 100%;">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@category.CategoryName</h5>
                   
                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Category" asp-action="Edit" asp-route-id="@category.Id" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Edit
                        </a>
                    }

                </div>
            </div>
        </div>
    }
</div>
