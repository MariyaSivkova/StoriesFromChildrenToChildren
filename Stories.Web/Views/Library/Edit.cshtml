@using Stories.ViewModels.Library
@using Stories.ViewModels.Author
@model BookDetailsViewModel
@{
    ViewData["Title"] = "Edit Book";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="Edit" method="post">
    <img src="@Model.PathToCover" alt="@Model.Title" class="img-fluid img-thumbnail" />

    <div class="form-group">
        <label asp-for="Title" class="control-label"></label>
        <input asp-for="Title" class="form-control" value=@Model.Title />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Annotation" class="control-label"></label>
        <textarea asp-for="Annotation" class="form-control" rows="5">@Model.Annotation</textarea>
        <span asp-validation-for="Annotation" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Description" class="control-label"></label>
        <textarea asp-for="Description" class="form-control" rows="5">@Model.Description</textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="AuthorId" class="control-label">Author</label>
        <select name="AuthorId" class="form-control" id="AuthorId">
            @foreach (AuthorViewModel a in Model.Authors)
            {
                if (Model.Author.Id == a.Id)
                {
                    <option value="@a.Id" selected>@a.FirstName @a.LastName</option>
                }
                else
                {
                    <option value="@a.Id">@a.FirstName @a.LastName</option>
                }
            }
        </select>
        <span class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Date" class="control-label"></label>
        <input asp-for="Date" type="datetime-local" class="form-control" value="@(Model.Date.ToString("yyyy-MM-ddTHH:mm"))" />
        <span asp-validation-for="Date" class="text-danger"></span>
    </div>



    <div class="form-group mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}