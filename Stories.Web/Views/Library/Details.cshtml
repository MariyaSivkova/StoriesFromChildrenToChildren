@using Stories.ViewModels.Library
@model BookDetailsViewModel
@{
    ViewData["Title"] = "Book Details";
}

<h2>@ViewData["Title"]</h2>

<div class="container" style="margin-top:20px">
    <div class="row">
        <div class="col-md-4">
            <img src="@Model.PathToCover" alt="@Model.Title" class="img-fluid img-thumbnail" />

            <div class="mt-3 d-flex gap-2">
                <a asp-controller="Library" asp-action="Index" class="btn btn-secondary">Back</a>

                @if (!string.IsNullOrWhiteSpace(Model.PathToAudiobook))
                {
                    <a class="btn btn-success" href="@Model.PathToAudiobook" target="_blank">Listen / Download</a>
                }
                <a asp-controller="Library" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
                <a asp-controller="Library" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
            </div>
        </div>

        <div class="col-md-8">
            <h2>@Model.Title</h2>

            <p>
                <strong>Author:</strong>
                @if (Model.Author != null)
                {
                    @($"{Model.Author.FirstName} {Model.Author.LastName}")
                }
                else
                {
                    @:Unknown
                }
            </p>

            <p><strong>Category:</strong> @Model.Category.CategoryName</p>
            <p><strong>Added by:</strong> @Model.User.UserName</p>
            <p><strong>Date:</strong> @Model.Date.ToString("yyyy-MM-dd")</p>

            <hr />

            <h4>Annotation</h4>
            <p>@Model.Annotation</p>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <h4>Description</h4>
                <p>@Model.Description</p>
            }
        </div>
    </div>
</div>
