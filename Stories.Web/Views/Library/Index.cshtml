@using Stories.ViewModels.Library;

@model IEnumerable<Stories.ViewModels.Library.BookViewModel>

@{
    ViewData["Title"] = "Books";
}

<div class="d-flex justify-content-between align-items-center mb-3" style="margin-top: 20px;">
    <h2>@ViewData["Title"]</h2>

    @if (User?.Identity?.IsAuthenticated == true)
    {
        <a asp-controller="Library" asp-action="Add" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add New Book
        </a>
    }
</div>
<hr />

<div class="row text-center">
    @foreach (BookViewModel book in Model)
    {
        <div class="col-md-3 mb-4">
            <div class="card h-100" style="width: 100%;">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@book.Title</h5>
                    <div class="d-flex justify-content-between mt-auto">
                        <img src="@book.PathToCover" title="title" alt="additional title" class="img-thumbnail" width="120" />
                        <div class="p-2 bd-highlight">@book.Anotation</div>
                    </div>

                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Library" asp-action="Details" asp-route-id="@book.Id" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Details
                        </a>
                    }

                </div>
            </div>
        </div>
    }
</div>
