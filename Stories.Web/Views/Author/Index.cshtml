@using Stories.ViewModels.Author
@model IEnumerable<AuthorViewModel>
@{
    ViewData["Title"] = "All Authors";
}

<div class="d-flex justify-content-between align-items-center mb-3" style="margin-top: 20px;">
    <h2>@ViewData["Title"]</h2>

    @if (User?.Identity?.IsAuthenticated == true)
    {
        <a asp-controller="Author" asp-action="Add" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add New Author
        </a>
    }
</div>
<hr />

<div class="row text-center">
    @foreach (var author in Model)
    {
        <div class="col-md-3 mb-4">
            <div class="card h-100" style="width: 100%;">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@author.FirstName @author.LastName</h5>
                    <div class="d-flex justify-content-between mt-auto">
                        @if (author.Biography != null)
                        {
                            @author.Biography
                        }
                    </div>
                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Author" asp-action="Edit" asp-route-id="@author.Id" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Edit
                        </a>
                    }

                </div>
            </div>
        </div>
    }
</div>
